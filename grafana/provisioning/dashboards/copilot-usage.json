{
  "title": "GitHub Copilot — Usage & Performance",
  "uid": "copilot-usage",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(copilot_gen_ai_client_token_usage_sum, gen_ai_request_model)",
        "label": "Model",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Input Tokens (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] }, "unit": "locale" } },
      "targets": [
        {
          "expr": "sum(increase(copilot_gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\", gen_ai_request_model=~\"$model\"}[24h]))",
          "legendFormat": "Input tokens"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Output Tokens (24h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "locale" } },
      "targets": [
        {
          "expr": "sum(increase(copilot_gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\", gen_ai_request_model=~\"$model\"}[24h]))",
          "legendFormat": "Output tokens"
        }
      ]
    },
    {
      "id": 3,
      "title": "Chat Sessions (24h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] }, "unit": "short" } },
      "targets": [
        {
          "expr": "sum(increase(copilot_copilot_chat_session_count_total[24h]))",
          "legendFormat": "Sessions"
        }
      ]
    },
    {
      "id": 4,
      "title": "Edit Acceptance Rate (24h)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.75 }] }, "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "expr": "sum(increase(copilot_copilot_chat_edit_acceptance_count_total{copilot_chat_edit_outcome=\"accepted\"}[24h])) / sum(increase(copilot_copilot_chat_edit_acceptance_count_total[24h]))",
          "legendFormat": "Acceptance rate"
        }
      ]
    },
    {
      "id": 5,
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (gen_ai_request_model) (rate(copilot_gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\", gen_ai_request_model=~\"$model\"}[5m]) * 300)",
          "legendFormat": "Input — {{gen_ai_request_model}}"
        },
        {
          "expr": "sum by (gen_ai_request_model) (rate(copilot_gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\", gen_ai_request_model=~\"$model\"}[5m]) * 300)",
          "legendFormat": "Output — {{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "LLM Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(copilot_gen_ai_client_operation_duration_bucket{gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(copilot_gen_ai_client_operation_duration_bucket{gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(copilot_gen_ai_client_operation_duration_bucket{gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "title": "Tool Call Success Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } } },
      "targets": [
        {
          "expr": "sum by (gen_ai_tool_name) (rate(copilot_copilot_chat_tool_call_count_total{success=\"true\"}[5m])) / sum by (gen_ai_tool_name) (rate(copilot_copilot_chat_tool_call_count_total[5m]))",
          "legendFormat": "{{gen_ai_tool_name}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Time to First Token",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, gen_ai_request_model) (rate(copilot_copilot_chat_time_to_first_token_bucket{gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p50 — {{gen_ai_request_model}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, gen_ai_request_model) (rate(copilot_copilot_chat_time_to_first_token_bucket{gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p95 — {{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Edit Acceptance by Source",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "xField": "copilot_chat_edit_source", "stacking": "normal", "xTickLabelRotation": -45, "xTickLabelMaxLength": 20 },
      "targets": [
        {
          "expr": "sum by (copilot_chat_edit_source, copilot_chat_edit_outcome) (increase(copilot_copilot_chat_edit_acceptance_count_total[24h]))",
          "legendFormat": "{{copilot_chat_edit_source}} — {{copilot_chat_edit_outcome}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Lines of Code Added/Removed by Agent",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "xTickLabelRotation": -45, "xTickLabelMaxLength": 20 },
      "targets": [
        {
          "expr": "sum by (type) (increase(copilot_copilot_chat_lines_of_code_count_total[24h]))",
          "legendFormat": "{{type}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Request Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "(sum by (gen_ai_request_model) (rate(copilot_gen_ai_client_operation_duration_count{error_type!=\"\", gen_ai_request_model=~\"$model\"}[5m])) or on() vector(0)) / sum by (gen_ai_request_model) (rate(copilot_gen_ai_client_operation_duration_count{gen_ai_request_model=~\"$model\"}[5m]))",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Edit Acceptance Trend",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(copilot_copilot_chat_edit_acceptance_count_total{copilot_chat_edit_outcome=\"accepted\"}[5m])) / sum(rate(copilot_copilot_chat_edit_acceptance_count_total[5m]))",
          "legendFormat": "Acceptance rate"
        }
      ]
    },
    {
      "id": 13,
      "title": "Top Tools by Call Volume (24h)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "orientation": "horizontal", "xField": "gen_ai_tool_name", "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "expr": "topk(10, sum by (gen_ai_tool_name) (increase(copilot_copilot_chat_tool_call_count_total[24h])))",
          "legendFormat": "{{gen_ai_tool_name}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 14,
      "title": "Token Efficiency (Output / Input Ratio)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "decimals": 2 } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (gen_ai_request_model) (rate(copilot_gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\", gen_ai_request_model=~\"$model\"}[5m])) / sum by (gen_ai_request_model) (rate(copilot_gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\", gen_ai_request_model=~\"$model\"}[5m]))",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 15,
      "title": "Sessions per Hour",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 44, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "continuous-blues" }, "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(rate(copilot_copilot_chat_session_count_total[5m]) * 3600)",
          "legendFormat": "Sessions/hr"
        }
      ]
    },
    {
      "id": 16,
      "title": "Request Throughput (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 44, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (gen_ai_request_model) (rate(copilot_gen_ai_client_operation_duration_count{gen_ai_request_model=~\"$model\"}[5m])) * 60",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 17,
      "title": "Lines of Code Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 52, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (type) (rate(copilot_copilot_chat_lines_of_code_count_total[5m]) * 300)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 18,
      "title": "Token Share by Model (24h)",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 52, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum by (gen_ai_request_model) (increase(copilot_gen_ai_client_token_usage_sum{gen_ai_request_model=~\"$model\"}[24h]))",
          "legendFormat": "{{gen_ai_request_model}}",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 19,
      "title": "Recent Traces (Jaeger)",
      "type": "table",
      "gridPos": { "x": 0, "y": 60, "w": 24, "h": 10 },
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "StartTime", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace",
                    "url": "",
                    "internal": {
                      "datasourceUid": "jaeger",
                      "datasourceName": "Jaeger",
                      "query": { "queryType": "getTrace", "query": "${__value.raw}" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "queryType": "search",
          "service": "copilot-chat",
          "limit": 20
        }
      ]
    },
    {
      "id": 20,
      "title": "Agent Invocation Duration (p50/p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 70, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, gen_ai_agent_name) (rate(copilot_copilot_chat_agent_invocation_duration_bucket[5m])))",
          "legendFormat": "p50 — {{gen_ai_agent_name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, gen_ai_agent_name) (rate(copilot_copilot_chat_agent_invocation_duration_bucket[5m])))",
          "legendFormat": "p95 — {{gen_ai_agent_name}}"
        }
      ]
    },
    {
      "id": 21,
      "title": "Turns per Agent Invocation (p50/p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 70, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, gen_ai_agent_name) (rate(copilot_copilot_chat_agent_turn_count_bucket[5m])))",
          "legendFormat": "p50 — {{gen_ai_agent_name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, gen_ai_agent_name) (rate(copilot_copilot_chat_agent_turn_count_bucket[5m])))",
          "legendFormat": "p95 — {{gen_ai_agent_name}}"
        }
      ]
    },
    {
      "id": 22,
      "title": "Tool Call Latency p95 by Tool",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 78, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, gen_ai_tool_name) (rate(copilot_copilot_chat_tool_call_duration_bucket[5m])))",
          "legendFormat": "{{gen_ai_tool_name}}"
        }
      ]
    },
    {
      "id": 23,
      "title": "Edit Survival (higher = better)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 78, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(copilot_copilot_chat_edit_survival_four_gram_sum[30m])) / sum(rate(copilot_copilot_chat_edit_survival_four_gram_count[30m]))",
          "legendFormat": "4-gram avg"
        },
        {
          "expr": "sum(rate(copilot_copilot_chat_edit_survival_no_revert_sum[30m])) / sum(rate(copilot_copilot_chat_edit_survival_no_revert_count[30m]))",
          "legendFormat": "no-revert avg"
        }
      ]
    },
    {
      "id": 24,
      "title": "File-level Edit Outcomes (24h)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 86, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "xField": "copilot_chat_edit_outcome", "xTickLabelRotation": -45, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (copilot_chat_edit_outcome, copilot_chat_edit_source) (increase(copilot_copilot_chat_chat_edit_outcome_count_total[24h]))",
          "legendFormat": "{{copilot_chat_edit_outcome}} — {{copilot_chat_edit_source}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 25,
      "title": "Top Languages by Accepted Edits (24h)",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 86, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "orientation": "horizontal", "xField": "copilot_chat_language_id", "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "expr": "topk(10, sum by (copilot_chat_language_id) (increase(copilot_copilot_chat_edit_acceptance_count_total{copilot_chat_edit_outcome=\"accepted\"}[24h])))",
          "legendFormat": "{{copilot_chat_language_id}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 26,
      "title": "Unique Sessions (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 94, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] }, "unit": "short" } },
      "targets": [
        {
          "expr": "count(count by (session_id) (copilot_copilot_chat_session_count_total))",
          "legendFormat": "Unique sessions"
        }
      ]
    },
    {
      "id": 27,
      "title": "Avg Tokens per LLM Call (24h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 94, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] }, "unit": "short", "decimals": 0 } },
      "targets": [
        {
