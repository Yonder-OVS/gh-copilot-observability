{
  "title": "Claude Code Usage & Cost",
  "uid": "claude-code-usage",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(copilot_claude_code_session_count_total, service_name)",
        "label": "Service",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "claude-code",
          "value": "claude-code"
        },
        "sort": 1
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(copilot_claude_code_token_usage_tokens_total{service_name=~\"$service\"}, model)",
        "label": "Model",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "user",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(copilot_claude_code_session_count_total{service_name=~\"$service\"}, user_email)",
        "label": "User",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Cost (24h)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_claude_code_cost_usage_USD_total{service_name=~\"$service\", model=~\"$model\", user_email=~\"$user\"}[24h])) or vector(0)",
          "legendFormat": "USD"
        }
      ]
    },
    {
      "id": 2,
      "title": "Input Tokens (24h)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_claude_code_token_usage_tokens_total{service_name=~\"$service\", model=~\"$model\", user_email=~\"$user\", type=\"input\"}[24h])) or vector(0)",
          "legendFormat": "Input"
        }
      ]
    },
    {
      "id": 3,
      "title": "Output Tokens (24h)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_claude_code_token_usage_tokens_total{service_name=~\"$service\", model=~\"$model\", user_email=~\"$user\", type=\"output\"}[24h])) or vector(0)",
          "legendFormat": "Output"
        }
      ]
    },
    {
      "id": 4,
      "title": "Sessions (24h)",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_claude_code_session_count_total{service_name=~\"$service\", user_email=~\"$user\"}[24h])) or vector(0)",
          "legendFormat": "Sessions"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(copilot_claude_code_cost_usage_USD_total{service_name=~\"$service\", model=~\"$model\", user_email=~\"$user\"}[5m])) * 300",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (type, model) (rate(copilot_claude_code_token_usage_tokens_total{service_name=~\"$service\", model=~\"$model\", user_email=~\"$user\"}[5m])) * 300",
          "legendFormat": "{{model}} {{type}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Token Mix (24h)",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale"
        }
      },
      "targets": [
        {
          "expr": "sum by (type) (increase(copilot_claude_code_token_usage_tokens_total{service_name=~\"$service\", model=~\"$model\", user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Lines Changed (24h)",
      "type": "bargauge",
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale"
        }
      },
      "targets": [
        {
          "expr": "sum by (type) (increase(copilot_claude_code_lines_of_code_count_total{service_name=~\"$service\", user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Edit Decision Rate (24h)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(sum(increase(copilot_claude_code_code_edit_tool_decision_total{service_name=~\"$service\", user_email=~\"$user\", decision=\"accept\"}[24h])) / sum(increase(copilot_claude_code_code_edit_tool_decision_total{service_name=~\"$service\", user_email=~\"$user\"}[24h]))) or vector(0)",
          "legendFormat": "Accepted"
        }
      ]
    },
    {
      "id": 10,
      "title": "Active Time (24h)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_claude_code_active_time_total_seconds_total{service_name=~\"$service\", user_email=~\"$user\"}[24h])) or vector(0)",
          "legendFormat": "Active time"
        }
      ]
    },
    {
      "id": 11,
      "title": "Workflow Outputs (24h)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_claude_code_commit_count_total{service_name=~\"$service\", user_email=~\"$user\"}[24h])) or vector(0)",
          "legendFormat": "Commits"
        },
        {
          "expr": "sum(increase(copilot_claude_code_pull_request_count_total{service_name=~\"$service\", user_email=~\"$user\"}[24h])) or vector(0)",
          "legendFormat": "Pull requests"
        }
      ]
    },
    {
      "id": 12,
      "title": "Edit Decisions By Tool (24h)",
      "type": "bargauge",
      "gridPos": {
        "x": 8,
        "y": 20,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale"
        }
      },
      "targets": [
        {
          "expr": "sum by (tool_name, decision) (increase(copilot_claude_code_code_edit_tool_decision_total{service_name=~\"$service\", user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{tool_name}} {{decision}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Cost By Query Source (24h)",
      "type": "bargauge",
      "gridPos": {
        "x": 16,
        "y": 20,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "targets": [
        {
          "expr": "sum by (query_source) (increase(copilot_claude_code_cost_usage_USD_total{service_name=~\"$service\", model=~\"$model\", user_email=~\"$user\"}[24h]))",
          "legendFormat": "{{query_source}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Recent Claude Code Events",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
